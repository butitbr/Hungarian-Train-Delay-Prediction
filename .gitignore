# Environment variables (SECRETS!)
.env

# Virtual environment
.venv/
venv/
env/
ENV/

# Downloaded GTFS files (but allow stops.txt)
data/gtfs/*.zip
data/gtfs/latest/gtfs/*
!data/gtfs/latest/gtfs/stops.txt

# Processed datasets (optional to track)
data/ml_ready/
data/processed/

# Large binary files
data/generated_files/*.pkl
*.pkl
*.h5
*.joblib

# Allow collected data CSVs to be tracked
!data/collected/*.csv
!data/weather/*.csv
!logs/*.log

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Models (usually too large)
model/
models/

# Results and reports (generated)
results/
reports/

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~

# OS specific files
.DS_Store
Thumbs.db
desktop.ini

# Testing
.pytest_cache/
.coverage
htmlcov/

# Distribution / packaging
build/
dist/
*.egg-info/
